# ============================================================
# MODÈLE de configuration locale
# 1. Copier ce fichier : cp application-local.yaml.example application-local.yaml
# 2. Remplacer les valeurs par vos vraies informations
# ============================================================

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/outfitera_db
    username: postgres
    password: YOUR_POSTGRESQL_PASSWORD

  jpa:
    show-sql: true

  security:
    jwt:
      secret: YOUR_SECRET_KEY_MIN_32_CHARACTERS_LONG
      expiration: 86400000

server:
  port: 8080

logging:
  level:
    com.intern: DEBUG
